# Environment variables for local development
# This file is tracked in git - DO NOT add real secrets here
# For production, configure environment variables in Cloudflare Pages dashboard

# Ideal Postcodes API key for postcode lookup (REQUIRED for address lookup)
# Sign up at https://ideal-postcodes.co.uk (~2p per lookup)
# Set the actual key in Cloudflare Pages dashboard - never commit a real key here
# IDEAL_POSTCODES_API_KEY=your-production-key-here

# Google Maps Embed API key (optional - only needed if using Google Maps)
# Get a key from: https://console.cloud.google.com (enable Maps Embed API)
# Set the actual key in Cloudflare Pages dashboard - never commit a real key here
# GOOGLE_MAPS_API_KEY=

# Lead storage uses Cloudflare D1 (no env vars needed - configure binding in Pages dashboard)
# See migrations/0001_create_leads.sql for the database schema
