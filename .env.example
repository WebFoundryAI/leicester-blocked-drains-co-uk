# Ideal Postcodes API key for postcode lookup
# The 'iddqd' community key is used by default (15 lookups/day/IP)
# For production: sign up at https://ideal-postcodes.co.uk
IDEAL_POSTCODES_API_KEY=iddqd

# Lead storage uses Cloudflare D1 (no env vars needed - configure binding in Pages dashboard)
# See migrations/0001_create_leads.sql for the database schema
